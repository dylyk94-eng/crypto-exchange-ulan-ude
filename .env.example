TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

RATES_PROVIDER=coingecko
RATES_REQUEST_TIMEOUT_MS=8000

# Grinex integration
# Replace GRINEX_API_URL with the exact public ticker endpoint from https://api-documentation.grinex.io/#api
# If Grinex requires auth for that endpoint, also set GRINEX_API_KEY.
GRINEX_API_URL=https://api.grinex.io/public/markets/tickers
GRINEX_API_KEY=
GRINEX_MARKET_BTC=btcrub,BTCRUB,BTC-RUB
GRINEX_MARKET_ETH=ethrub,ETHRUB,ETH-RUB
GRINEX_MARKET_USDT=usdtrub,USDTRUB,USDT-RUB
GRINEX_MARKET_LTC=ltcrub,LTCRUB,LTC-RUB
GRINEX_MARKET_TRX=trxrub,TRXRUB,TRX-RUB
GRINEX_MARKET_BNB=bnbrub,BNBRUB,BNB-RUB

RATE_MARKUP_BTC=1.8
RATE_MARKUP_ETH=1.8
RATE_MARKUP_USDT=1.2
RATE_MARKUP_LTC=1.6
RATE_MARKUP_TRX=1.4
RATE_MARKUP_BNB=1.7
